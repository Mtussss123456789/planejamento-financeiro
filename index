========================================================== */
window.savePDF = function(){
  const renda = topRenda.textContent;
  const gastos = topGastos.textContent;
  const saldo = topSaldo.textContent;

  const autos = getFixosAutoForMonth(currentYear,currentMonth);

  function getList(type){
    const arr=[];
    document.querySelectorAll(`[data-type="${type}"] .item:not(.auto-parc)`).forEach(row=>{
      const title=row.querySelector(".title").value.trim();
      const value=row.querySelector(".value").value;
      if(title || value){
        arr.push({title:title||"(sem título)", value: format(+value||0)});
      }
    });
    return arr;
  }

  const rendaList = getList("renda");
  const invList = getList("inv");
  const fixoManualList = getList("fixo");
  const variList = getList("vari");

  const fixoAutoList = autos.map(a=>({
    title: a.title,
    value: format(+a.value||0)
  }));

  const html = `
  <html>
  <head>
    <meta charset="utf-8">
    <title>PDF</title>
    <style>
      body{ font-family: Arial; padding: 20px; color:#111; }
      h1{ margin:0 0 10px; }
      .meta{ margin: 0 0 18px; font-size:14px; }
      .grid{ display:flex; gap:10px; margin-bottom: 18px; }
      .card{ flex:1; padding:12px; border:1px solid #ccc; border-radius:12px; }
      .card strong{ display:block; margin-top:6px; font-size:16px; }
      h2{ margin:18px 0 8px; }
      table{ width:100%; border-collapse: collapse; }
      th,td{ border:1px solid #ddd; padding:8px; text-align:left; font-size:13px; }
      th{ background:#f3f3f3; }
    </style>
  </head>
  <body>
    <h1>Planejamento Financeiro</h1>
    <div class="meta"><b>Mês:</b> ${monthLabel(currentYear,currentMonth)}</div>

    <div class="grid">
      <div class="card"><span>Renda</span><strong>${renda}</strong></div>
      <div class="card"><span>Gastos</span><strong>${gastos}</strong></div>
      <div class="card"><span>Saldo</span><strong>${saldo}</strong></div>
    </div>

    ${makeTable("Renda", rendaList)}
    ${makeTable("Investimentos", invList)}
    ${makeTable("Gastos Fixos (Manuais)", fixoManualList)}
    ${makeTable("Gastos Fixos (Parcelamentos)", fixoAutoList)}
    ${makeTable("Gastos Variáveis", variList)}

    <script>
      window.onload = () => { window.print(); }
    <\/script>
  </body>
  </html>
  `;

  const w = window.open("", "_blank");
  w.document.open();
  w.document.write(html);
  w.document.close();
}

function makeTable(title, list){
  if(!list.length){
    return `<h2>${title}</h2><div style="opacity:.7">Nenhum item</div>`;
  }

  let rows = "";
  list.forEach(i=>{
    rows += `<tr><td>${escapeHtml(i.title)}</td><td>${i.value}</td></tr>`;
  });

  return `
    <h2>${title}</h2>
    <table>
      <thead><tr><th>Título</th><th>Valor</th></tr></thead>
      <tbody>${rows}</tbody>
    </table>
  `;
}

function escapeHtml(str){
  return (str||"")
    .replaceAll("&","&amp;")
    .replaceAll("<","&lt;")
    .replaceAll(">","&gt;")
    .replaceAll('"',"quot;")
    .replaceAll("'","&#039;");
}

